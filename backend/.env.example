# =============================================================================
# ELVA Support — Backend environment (copy to .env for local dev)
# On Render: set these in Dashboard → Environment (never commit .env)
# =============================================================================

NODE_ENV=development
PORT=3000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/elva-support-dev

# --- Auth & security ---
# Generate for production: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h
INTERNAL_API_KEY=change-this-internal-api-key-in-production

# --- URLs & CORS ---
# Comma-separated frontend origins (required in production)
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:3000
CORS_ALLOW_VERCEL_PREVIEWS=false

# --- Admin (ensured on every server start if missing) ---
ADMIN_EMAIL=admin@elvatech.in
ADMIN_PASSWORD=change-me
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# --- Notifications (outbound) ---
# Resend recommended on Render free tier (SMTP ports blocked).
NOTIFICATION_PROVIDER=RESEND
RESEND_API_KEY=
RESEND_FROM_NAME=ELVA Support
RESEND_TIMEOUT_MS=15000
NOTIFICATION_FALLBACK_ENABLED=false
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_POLL_MS=5000
NOTIFICATION_WORKER_BATCH_SIZE=10

# --- Outbound email identity ---
EMAIL_SUPPORT_ADDRESS=support@elvatech.in

# Gmail SMTP (local dev fallback if Resend not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tech.elva@gmail.com
SMTP_PASS=
SMTP_FROM_NAME=ELVA Support
SMTP_CONNECTION_TIMEOUT_MS=20000
SMTP_GREETING_TIMEOUT_MS=20000
SMTP_SOCKET_TIMEOUT_MS=30000

# --- Inbound email ---
# Local dev:  EMAIL_INBOUND_PROVIDER=imap  (polls Gmail — no Cloudflare needed)
# Production: EMAIL_INBOUND_PROVIDER=webhook (Cloudflare Email Worker → POST /api/webhooks/inbound-email)
#
# Generate webhook secret (use SAME value on Render + Cloudflare Worker):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_INBOUND_ENABLED=true
EMAIL_INBOUND_PROVIDER=webhook
EMAIL_INBOUND_WEBHOOK_SECRET=

# IMAP — only used when EMAIL_INBOUND_PROVIDER=imap
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=tech.elva@gmail.com
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=support@elvatech.in
EMAIL_IMAP_POLL_MS=180000
EMAIL_IMAP_POLL_TIMEOUT_MS=90000
EMAIL_IMAP_CONNECTION_TIMEOUT_MS=30000
EMAIL_IMAP_GREETING_TIMEOUT_MS=15000
EMAIL_IMAP_SOCKET_TIMEOUT_MS=45000
EMAIL_IMAP_BATCH_SIZE=10
EMAIL_IMAP_LOOKBACK_DAYS=3

# --- ELVA Notify (optional — only if NOTIFICATION_PROVIDER=ELVA_NOTIFY) ---
ELVA_NOTIFY_API_URL=https://api.notify.elvatech.in
ELVA_NOTIFY_APP_ID=
ELVA_NOTIFY_API_KEY=
ELVA_NOTIFY_BRAND_ID=
ELVA_NOTIFY_OTP_MODE=relay
ELVA_NOTIFY_TIMEOUT_MS=10000

# --- OTP & sessions ---
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LOCK_MINUTES=15
MERCHANT_SESSION_EXPIRES_HOURS=24
LOG_OTP_TO_CONSOLE=true
EXPOSE_OTP_IN_RESPONSE=false

# --- Rate limits ---
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_WINDOW_MS=900000

# --- Attachments ---
GOOGLE_DRIVE_MOCK=true
UPLOADS_DIR=uploads
UPLOAD_MAX_FILE_SIZE=10485760
GOOGLE_DRIVE_PARENT_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Dev only (disable on production) ---
LOG_VIEWER_ENABLED=true
