PORT=3000
MONGODB_URI=mongodb://localhost:27017/elva-support
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:4200
ADMIN_EMAIL=admin@elva.com
ADMIN_PASSWORD=Admin@123
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator
INTERNAL_API_KEY=change-this-internal-api-key-in-production
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LOCK_MINUTES=15
MERCHANT_SESSION_EXPIRES_HOURS=24
LOG_OTP_TO_CONSOLE=true
EXPOSE_OTP_IN_RESPONSE=false
SEED_MERCHANT_EMAIL=merchant@apnacart.demo
SEED_TEAM_LEAD_EMAIL=lead@apnacart.support
SEED_TEAM_LEAD_PASSWORD=Lead@12345
SEED_AGENT_EMAIL=agent@apnacart.support
SEED_AGENT_PASSWORD=Agent@12345
SEED_AGENT2_EMAIL=agent2@apnacart.support
SEED_AGENT2_PASSWORD=Agent@12345
GOOGLE_DRIVE_MOCK=true
API_BASE_URL=http://localhost:3000
UPLOADS_DIR=uploads
GOOGLE_DRIVE_PARENT_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
NODE_ENV=development
UPLOAD_MAX_FILE_SIZE=10485760
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_WINDOW_MS=900000
NOTIFICATION_PROVIDER=ELVA_NOTIFY
NOTIFICATION_FALLBACK_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_POLL_MS=5000
NOTIFICATION_WORKER_BATCH_SIZE=10
# ELVA Notify — register ELVA Support at https://notify.elvatech.in/playground
ELVA_NOTIFY_API_URL=https://api.notify.elvatech.in
ELVA_NOTIFY_APP_ID=
ELVA_NOTIFY_API_KEY=
ELVA_NOTIFY_BRAND_ID=
# native = ELVA Notify generates/verifies OTP (/otp/send, /otp/verify)
# relay = Support system OTP emailed via /notify HTML (use before brand approval)
ELVA_NOTIFY_OTP_MODE=native
ELVA_NOTIFY_TIMEOUT_MS=10000
